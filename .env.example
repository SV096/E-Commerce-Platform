PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Connection
# Get your MongoDB URI from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true

# Redis Cache (Upstash)
# Get your Redis URL from: https://console.upstash.com
UPSTASH_REDIS_URL=rediss://default:your_redis_token@your-domain.upstash.io:6379

# JWT Secrets (Generate secure random strings)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here

# Cloudinary (Image Upload)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (Payments)
# Use TEST keys for development (sk_test_...)
# Use LIVE keys for production (sk_live_...)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
