# Frontend Environment Variables

# Backend API URL (for production)
# Set this when deploying to production
# Example: https://your-backend-url.onrender.com
VITE_API_URL=https://your-backend-url-here.onrender.com

# Stripe Public Key
# Use TEST keys for development (pk_test_...)
# Use LIVE keys for production (pk_live_...)
# Get from: https://dashboard.stripe.com/apikeys
# NOTE: This is safe to expose in frontend code (public key)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
